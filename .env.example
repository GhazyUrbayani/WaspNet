# ============================================
# ChainRadar Environment Variables
# Copy to .env and fill in values
# ============================================

# --- Database ---
POSTGRES_USER=chainradar
POSTGRES_PASSWORD=chainradar_dev
POSTGRES_DB=chainradar
DATABASE_URL=postgresql+asyncpg://chainradar:chainradar_dev@localhost:5432/chainradar

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Dune SIM API (CORE) ---
# Get from: https://sim.dune.com/dashboard
SIM_API_KEY=your_dune_sim_api_key_here
SIM_BASE_URL=https://api.sim.dune.com/v1

# --- JWT Auth ---
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_WEBHOOK_URL=https://your-domain.com/api/telegram/webhook

# --- Email (Resend) ---
RESEND_API_KEY=your_resend_api_key_here
RESEND_FROM_EMAIL=alerts@chainradar.xyz

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# --- CORS ---
CORS_ORIGINS=http://localhost:3000,https://chainradar.vercel.app

# --- App ---
APP_ENV=development
APP_DEBUG=true
LOG_LEVEL=INFO
